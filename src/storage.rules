
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    /**
     * BEHEERHUB STORAGE RULES
     * Toegankelijk voor alle ingelogde gebruikers.
     * Dit staat uploads toe voor logo's, schademeldingen en documenten.
     */
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
