rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // Volledige toegang voor alle ingelogde gebruikers.
    // Dit zorgt ervoor dat de AI Training sjablonen in settings/ altijd schrijfbaar zijn.
    match /{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}