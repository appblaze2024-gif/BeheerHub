rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // Volledige toegang voor alle ingelogde gebruikers om de AI Training en meldingen te ondersteunen.
    // Dit staat ook toe dat kiosk-accounts (gebruikt voor NFC) instellingen kunnen aanpassen indien nodig.
    match /{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}
