
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    function isSignedIn() {
      return request.auth != null;
    }

    match /meldingen/{meldingId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf');
    }
    
    match /projects/{projectId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.resource.size < 50 * 1024 * 1024;
    }

    match /voertuigen/{id}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.resource.contentType.matches('image/.*');
    }
    
    match /machines/{id}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.resource.contentType.matches('image/.*');
    }
    
    match /settings/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /damages/{allPaths=**} {
      allow read, write: if isSignedIn();
    }
    
    match /documents/{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}
