rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // Volledige toegang voor alle ingelogde gebruikers om de AI Training en meldingen te ondersteunen.
    // Inclusief de settings map voor het uploaden van trainings-PDF's.
    match /{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}
