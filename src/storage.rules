rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    /**
     * BEHEERHUB STORAGE RULES
     * Toegankelijk voor alle ingelogde gebruikers (inclusief kiosk-accounts).
     */
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Specifieke regels voor instellingen en meldingen om toegang te garanderen voor AI training en doorzetten
    match /settings/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    match /meldingen/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
