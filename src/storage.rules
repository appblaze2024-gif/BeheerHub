rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // Specifieke toegang voor instellingen (AI Training, etc.)
    // We staan alle acties toe voor ingelogde gebruikers om permissiefouten bij sjablonen te voorkomen.
    match /settings/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Algemene toegang voor overige bestanden
    match /{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}
