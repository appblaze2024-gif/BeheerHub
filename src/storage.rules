rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // Specifieke toegang voor AI Training sjablonen in de settings map.
    // Dit zorgt ervoor dat Super Admins en kiosk-accounts altijd sjablonen kunnen beheren.
    match /settings/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Algemene toegang voor overige melding-gerelateerde opslag.
    match /{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}
