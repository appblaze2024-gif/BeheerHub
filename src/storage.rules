rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Schrijf- en leesrechten voor alle ingelogde gebruikers (inclusief kiosk-accounts)
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Specifieke regel voor instellingenmap om AI Training uploads te garanderen
    match /settings/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}