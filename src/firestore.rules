rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIES ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && userExists() && getUserData().role == 'Super admin';
    }

    function isPrivileged() {
      return isSignedIn() && userExists() && (getUserData().role == 'Super admin' || getUserData().role == 'toezichthouder');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- RULES ---

    // Gedeelde kaarten - Publiek toegankelijk voor reads
    match /shared_maps/{mapId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;
    }

    // Objecten (GIS)
    match /objects/{objectId} {
      allow read, get, list: if isSignedIn();
      allow write: if isPrivileged();
    }

    // Gebruikersprofielen
    match /users/{userId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      allow update: if (isSignedIn() && request.auth.uid == userId && 
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'permissions'])) 
                    || isAdmin();
      allow delete: if isAdmin();

      match /folders/{folderId} {
        allow read, list, get, write: if isSignedIn() && (request.auth.uid == userId || isPrivileged());
      }

      match /gisFolders/{folderId} {
        allow read: if true; // Toestaan voor gedeelde weergave
        allow write: if isOwner(userId);
      }

      match /gisLayers/{layerId} {
        allow read: if true; // Toestaan voor gedeelde weergave
        allow write: if isOwner(userId);
      }

      match /messages/{messageId} {
        allow read, list: if isSignedIn() && (request.auth.uid == userId || request.auth.uid == resource.data.fromUserId);
        allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid;
        allow update, delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /routes/{routeId} {
        allow read, list: if isSignedIn() && (request.auth.uid == userId || isPrivileged());
        allow write: if isSignedIn() && (request.auth.uid == userId || isPrivileged());
      }
    }

    // Projecten
    match /projects/{projectId} {
      allow read, get, list: if isSignedIn();
      allow write: if isPrivileged();

      match /{allSubcollections=**} {
        allow read, get, list: if isSignedIn();
        allow write: if isPrivileged();
      }
    }

    // Meldingen
    match /meldingen/{meldingId} {
      allow read, list: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isPrivileged();
    }

    // Wagenpark en Machines
    match /voertuigen/{id} {
      allow read, list: if isSignedIn();
      allow write: if isPrivileged();
      
      match /{allSubcollections=**} {
        allow read, list: if isSignedIn();
        allow write: if isPrivileged();
      }
    }
    
    match /machines/{id} {
      allow read, list: if isSignedIn();
      allow write: if isPrivileged();
      
      match /{allSubcollections=**} {
        allow read, list: if isSignedIn();
        allow write: if isPrivileged();
      }
    }

    // Algemene instellingen
    match /settings/{settingId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // Fallback voor admins
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
