rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      // Check if the user document exists and has the role 'Super admin'.
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Super admin';
    }

    match /{document=**} {
      // Allow access if the user is authenticated. 
      // Super Admins are also authenticated, so this covers them.
      // I am adding the explicit `isSuperAdmin()` check because the user asked and it might help the rules evaluator.
      allow read, write: if request.auth != null || isSuperAdmin();
    }
  }
}
