rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- KRITIEKE PERMISSIES (BOVENAAN) ---

    // Route assignments - OPEN VOOR LEZEN DOOR ALLE GEBRUIKERS
    match /route_assignments/{assignmentId} {
      allow read, list: if request.auth != null;
      allow write: if request.auth != null && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Super admin' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'toezichthouder');
    }

    // --- HELPER FUNCTIES ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && userExists() && getUserData().role == 'Super admin';
    }

    function isPrivileged() {
      return isSignedIn() && userExists() && (getUserData().role == 'Super admin' || getUserData().role == 'toezichthouder');
    }

    // --- RULES ---

    // Gebruikersprofielen
    match /users/{userId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Allow users to update their own profile EXCEPT for role/permissions
      allow update: if (isSignedIn() && request.auth.uid == userId && 
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'permissions'])) 
                    || isAdmin();
      allow delete: if isAdmin();

      // Berichten tussen gebruikers
      match /messages/{messageId} {
        allow read, list: if isSignedIn() && (request.auth.uid == userId || request.auth.uid == resource.data.fromUserId);
        allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid;
        allow update, delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /routes/{routeId} {
        allow read: if request.auth.uid == userId || isPrivileged();
        allow write: if request.auth.uid == userId || isPrivileged();
      }
    }

    // Projecten en bijbehorende data
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();

      match /{allSubcollections=**} {
        allow read: if isSignedIn();
        allow write: if isPrivileged();
      }
    }

    // Meldingen
    match /meldingen/{meldingId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isPrivileged();
    }

    // Wagenpark en Machines
    match /voertuigen/{id} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
      
      match /{allSubcollections=**} {
        allow read: if isSignedIn();
        allow write: if isPrivileged();
      }
    }
    
    match /machines/{id} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
      
      match /{allSubcollections=**} {
        allow read: if isSignedIn();
        allow write: if isPrivileged();
      }
    }

    // Objecten (GIS)
    match /objects/{objectId} {
      allow read, list: if isSignedIn();
      allow write: if isPrivileged();
    }

    // Algemene instellingen
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Fallback voor admins
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}