
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * BEHEERHUB SECURITY RULES
     * Gecentraliseerde toegangscontrole op basis van rollen.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().role == role;
    }

    function isPrivileged() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().role in ['Super admin', 'toezichthouder'];
    }

    // GLOBALE REGEL: Super admin mag alles
    match /{document=**} {
      allow read, write: if hasRole('Super admin');
    }

    // Gebruikersprofielen
    match /users/{userId} {
      // Iedereen mag profielen inzien (voor zoekfuncties en dialogen)
      allow read: if isSignedIn();
      // Alleen eigenaar of admin mag schrijven
      allow write: if isOwner(userId);

      // Routes subcollectie (Rittenregistratie)
      match /routes/{routeId} {
        // Geprivilegieerde gebruikers moeten alle ritten kunnen inzien voor rapportages
        allow read: if isOwner(userId) || isPrivileged();
        allow write: if isOwner(userId);
      }
    }

    // Projecten en bijbehorende data
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged() || hasRole('ondersteuner');

      match /{allSubcollections=**} {
        allow read: if isSignedIn();
        allow write: if isPrivileged() || hasRole('ondersteuner');
      }
    }

    // Personeelsbestand
    match /medewerkers/{medewerkerId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged() || hasRole('ondersteuner');
    }

    // Meldingen en werkbonnen
    match /meldingen/{meldingId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // IoT Sensoren
    match /sensors/{sensorId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Wagenpark en Materieel
    match /voertuigen/{id} {
      allow read: if isSignedIn();
      allow write: if isPrivileged() || hasRole('ondersteuner');
      match /{allSubcollections=**} {
        allow read: if isSignedIn();
        allow write: if isPrivileged() || hasRole('ondersteuner');
      }
    }
    match /machines/{id} {
      allow read: if isSignedIn();
      allow write: if isPrivileged() || hasRole('ondersteuner');
      match /{allSubcollections=**} {
        allow read: if isSignedIn();
        allow write: if isPrivileged() || hasRole('ondersteuner');
      }
    }

    // Areaal objecten
    match /objects/{objectId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    // Systeeminstellingen
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
  }
}
