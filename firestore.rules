/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model for user-specific data,
 * while allowing collaborative access to shared application data like vehicles.
 *
 * Data Structure:
 * - User-specific data is nested under `/users/{userId}`.
 * - Shared data like vehicles is at the root level in `/voertuigen`.
 *
 * Key Security Decisions:
 * - User Data Privacy: A user's root document and their private subcollections are only accessible by them.
 * - Vehicle Data Openness: All authenticated users can read vehicle information and manage related
 *   subcollections (actions, maintenance, damages) to facilitate collaboration.
 * - Prevent User Enumeration: Listing the top-level `/users` collection is forbidden.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to promote readable, secure, and maintainable rules.
    
    /**
     * isSignedIn
     * @description Checks if a user is authenticated.
     * @returns {boolean} True if the user has a valid auth object.
     */
    function isSignedIn() {
      return request.auth != null;
    }
    
    /**
     * isOwner
     * @description Checks if the requesting user is the owner of the document, based on the userId in the path.
     * @param {string} userId The user ID from the document path.
     * @returns {boolean} True if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
     * isExistingOwner
     * @description A stricter version of isOwner used for updates and deletes.
     * It ensures the document already exists before allowing the operation.
     * @param {string} userId The user ID from the document path.
     * @returns {boolean} True if the user is the owner and the document exists.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * isAdmin
     * @description Checks if the requesting user has the 'admin' role in their user profile.
     * @returns {boolean} True if the user is an admin.
     */
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }


    /**
     * @description Manages the root projects collection. Any authenticated user can manage projects.
     */
    match /projects/{projectId} {
       allow read, write: if isSignedIn();
       
       /**
        * @description Secures project-specific shifts. Any authenticated user can manage them.
        */
       match /diensten/{dienstId} {
         allow read, write: if isSignedIn();
       }

       /**
        * @description Secures project-specific booking rules. Any authenticated user can manage them.
        */
       match /boekingregels/{boekingregelId} {
         allow read, write: if isSignedIn();
       }

       /**
        * @description Secures project-specific files. Any authenticated user can manage them.
        */
       match /bestanden/{bestandId} {
         allow read, write: if isSignedIn();
       }

       /**
        * @description Secures project-specific appointments. Any authenticated user can manage them.
        */
       match /afspraken/{afspraakId} {
         allow read, write: if isSignedIn();
       }
       /**
        * @description Secures project-specific organization contacts. Any authenticated user can manage them.
        */
       match /organisatie/{contactId} {
         allow read, write: if isSignedIn();
       }
    }
    
     /**
     * @description Manages the root employees collection. Any authenticated user can manage employees.
     */
    match /medewerkers/{medewerkerId} {
      allow read, write: if isSignedIn();
    }
    
    /**
     * @description Manages the root user document. A user can manage their own document.
     *   Admins can list and manage all user profiles.
     */
    match /users/{userId} {
      allow get, update: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow delete: if false; // Deleting users is a sensitive operation, disable for now.

      /**
       * @description Secures a user's route history.
       */
      match /routes/{routeId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }

    /**
     * @description Manages the root objects collection. Any authenticated user can manage objects.
     */
    match /objects/{objectId} {
        allow read, write: if isSignedIn();
    }
    
    /**
     * @description Manages the root issues (meldingen) collection. Any authenticated user can manage issues.
     */
    match /meldingen/{meldingId} {
        allow read, write: if isSignedIn();
    }
    
    /**
     * @description Secures a user's private revenue entries. Only the authenticated owner
     *   of the data can perform any read or write operations.
     */
    match /users/{userId}/revenues/{revenueId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
    
    /**
     * @description Secures a user's private expense entries. Only the authenticated owner
     *   of the data can perform any read or write operations.
     */
    match /users/{userId}/expenses/{expenseId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
    
    /**
     * @description Secures a user's private appointment entries. Only the authenticated owner
     *   of the data can perform any read or write operations.
     */
    match /users/{userId}/appointments/{appointmentId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages shared vehicle data. All authenticated users can read
     *   the list of vehicles and their details. Writing is restricted.
     */
    match /voertuigen/{vehicleId} {
      allow get, list: if isSignedIn();
      // Allow creation/updates only if the user is signed in.
      // More specific validation could be added here.
      allow create, update: if isSignedIn();
      allow delete: if false; // Deleting vehicles is disallowed for now.
    }
    
    /**
     * @description Secures vehicle-related subcollections like actions, maintenance, and damages.
     *   Any authenticated user can read and write to these collections, a
     *   collaborative management of vehicle data.
     */
    match /voertuigen/{vehicleId}/{subcollection}/{docId} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Manages shared machine data. All authenticated users can read
     *   the list of machines and their details. Writing is restricted.
     */
    match /machines/{machineId} {
      allow get, list: if isSignedIn();
      // Allow creation/updates only if the user is signed in.
      allow create, update: if isSignedIn();
      allow delete: if false; // Deleting machines is disallowed for now.
    }
    
    /**
     * @description Secures machine-related subcollections like actions, maintenance, and damages.
     *   Any authenticated user can read and write to these collections for
     *   collaborative management of machine data.
     */
    match /machines/{machineId}/{subcollection}/{docId} {
      allow read, write: if isSignedIn();
    }
  }
}
