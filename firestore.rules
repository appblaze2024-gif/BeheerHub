rules_version = '2';

/**
 * This ruleset enforces a hybrid security model for a small business ERP application.
 *
 * Core Philosophy:
 * - User data (revenues, expenses, appointments) is strictly private and isolated.
 * - Application-wide data (vehicles) is accessible to all authenticated users.
 *
 * Data Structure:
 * - User-specific data is nested under `/users/{userId}`.
 * - Shared data, like vehicles, is in a root-level collection `/voertuigen`.
 *
 * Key Security Decisions:
 * - Strict Data Isolation for Users: A user can NEVER access data belonging to another user.
 * - Shared Data Access: All authenticated users can read and write to the shared `voertuigen` collection.
 * - No User Listing: It is not possible to list all documents in the top-level `/users` collection.
 * - Ownership-Based Access: For user data, all operations are granted based on the user's ID in the path.
 *
 * Denormalization for Authorization:
 * By nesting user data, the `userId` required for authorization is always in the path,
 * avoiding slow and costly `get()` calls in security rules.
 */
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for clear, reusable logic.
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Secures a user's root document, the container for their private data.
     */
    match /users/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      /**
       * Secures revenue documents, ensuring they are private to the user.
       */
      match /revenues/{revenueId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }

      /**
       * Secures expense documents, ensuring they are private to the user.
       */
      match /expenses/{expenseId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }

      /**
       * Secures appointment documents, ensuring they are private to the user.
       */
      match /appointments/{appointmentId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }

    /**
     * @description
     *   Secures the central `voertuigen` collection.
     * @path
     *   /voertuigen/{voertuigId}
     * @allow
     *   Any authenticated user can read, create, update, and delete any vehicle document.
     *   This allows for central management of the vehicle fleet by all app users.
     * @deny
     *   Unauthenticated users have no access.
     * @principle
     *   Shared-data model for application-wide resources.
     */
    match /voertuigen/{voertuigId} {
      allow read, write: if isSignedIn();
    }
  }
}
