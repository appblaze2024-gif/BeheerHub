
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * BEHEERHUB SECURITY RULES
     * Geoptimaliseerd voor infra-management en medewerker-tracking.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().role == role;
    }

    function isPrivileged() {
      return hasRole('Super admin') || hasRole('toezichthouder');
    }

    // Algemene regel voor alle collecties: toegang voor ingelogde gebruikers.
    // Specifieke beperkingen worden hieronder gedefinieerd.
    match /{document=**} {
      allow read, write: if isSignedIn();
    }

    // Specifieke regel voor gebruikersprofielen
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || hasRole('Super admin');
    }

    // Specifieke regel voor gebruikersroutes om toezicht mogelijk te maken
    match /users/{userId}/routes/{routeId} {
      allow read: if isOwner(userId) || isPrivileged();
      allow write: if isOwner(userId) || hasRole('Super admin');
    }
    
    // Project specifieke subcollecties
    match /projects/{projectId}/{subCollection=**} {
      allow read, write: if isSignedIn();
    }
    
    // Materieel specifieke subcollecties (onderhoud, schade, etc)
    match /voertuigen/{id}/{subCollection=**} {
      allow read, write: if isSignedIn();
    }
    match /machines/{id}/{subCollection=**} {
      allow read, write: if isSignedIn();
    }
  }
}
