
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIES ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && userExists() && getUserData().role == 'Super admin';
    }

    function isPrivileged() {
      return isSignedIn() && userExists() && (getUserData().role == 'Super admin' || getUserData().role == 'toezichthouder');
    }

    // --- RULES ---

    // Gebruikersprofielen
    match /users/{userId} {
      allow read, list: if isSignedIn();
      // Voorkom dat gebruikers hun eigen rol of permissies aanpassen (Privilege Escalation Protection)
      allow update: if (request.auth.uid == userId && 
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'permissions'])) 
                    || isAdmin();
      allow create, delete: if isAdmin();

      // Berichten tussen gebruikers: alleen deelnemers mogen lezen/schrijven
      match /messages/{messageId} {
        allow read, list: if isSignedIn() && (request.auth.uid == userId || request.auth.uid == resource.data.fromUserId);
        allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid;
        allow update, delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /routes/{routeId} {
        allow read: if request.auth.uid == userId || isPrivileged();
        allow write: if request.auth.uid == userId || isPrivileged();
      }
    }

    // Projecten en bijbehorende data
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();

      match /{allSubcollections=**} {
        allow read: if isSignedIn();
        allow write: if isPrivileged();
      }
    }

    // Meldingen: Technici moeten meldingen kunnen updaten (afhandelen)
    match /meldingen/{meldingId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isPrivileged();
    }

    // Wagenpark en Machines
    match /voertuigen/{id} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
      
      match /{allSubcollections=**} {
        allow read: if isSignedIn();
        allow write: if isPrivileged();
      }
    }
    
    match /machines/{id} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
      
      match /{allSubcollections=**} {
        allow read: if isSignedIn();
        allow write: if isPrivileged();
      }
    }

    // Planning en Milestones
    match /annual_planning/{document=**} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /annual_planning_sections/{document=**} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /annual_planning_configs/{document=**} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
    
    match /annual_milestones/{document=**} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    // Aannemers
    match /contractors/{contractorId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();

      match /{allSubcollections=**} {
        allow read: if isSignedIn();
        allow write: if isPrivileged();
      }
    }

    // IoT Sensoren
    match /sensors/{sensorId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Sensoren moeten via API kunnen schrijven
    }

    // Algemene instellingen
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Fallback voor admins
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
