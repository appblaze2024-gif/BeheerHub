rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // A single function for checking permissions, making only one document read.
    function hasPermission(module, action) {
      if (!isSignedIn()) {
        return false;
      }
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));

      if (!userDoc.exists) {
        return false;
      }
      if (userDoc.data.role == 'Super admin') {
        return true;
      }
      return module in userDoc.data.permissions &&
             action in userDoc.data.permissions[module] &&
             userDoc.data.permissions[module][action] == true;
    }
    
    // A function to check against a list of roles with one document read.
    function isOneOfRoles(roles) {
      if (!isSignedIn()) {
        return false;
      }
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc.exists && userDoc.data.role in roles;
    }

    match /projects/{projectId} {
       allow read, write: if isSignedIn();

       match /diensten/{dienstId} {
         allow read, write: if isSignedIn();
       }

       match /boekingregels/{boekingregelId} {
         allow read, write: if isSignedIn();
       }

       match /bestanden/{bestandId} {
         allow read, write: if isSignedIn();
       }

       match /afspraken/{afspraakId} {
         allow read, write: if isSignedIn();
       }

       match /organisatie/{contactId} {
         allow read, write: if isSignedIn();
       }

       match /besteksmeldingen/{besteksmeldingId} {
         allow read, write: if isSignedIn();
       }

       match /schouwingen/{schouwId} {
         allow read, write: if isSignedIn();
       }
    }

    match /medewerkers/{medewerkerId} {
      allow get, list: if isSignedIn();
      allow create: if hasPermission('employees', 'create');
      allow update: if hasPermission('employees', 'edit');
      allow delete: if hasPermission('employees', 'delete');
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || hasPermission('users', 'view');
      allow list: if hasPermission('users', 'view') || request.auth.uid == '5l56WagvKGXxqnUJ5t4oBlnJSM73';
      allow create: if hasPermission('users', 'create');
      allow update: if isOwner(userId) || hasPermission('users', 'edit');
      allow delete: if false;

      // This rule only covers direct access for the owner.
      // Admin/supervisor access for specific user's routes is handled by the collection group rule.
      match /routes/{routeId} {
        allow get, list: if isOwner(userId);
        allow create, update, delete: if isOwner(userId) && hasPermission('navigation', 'use');
      }
    }

    // This rule is specifically for the collectionGroup query, but also allows admins
    // to get/list routes of specific users directly.
    match /{path=**}/routes/{routeId} {
      allow get, list: if isOneOfRoles({ 'Super admin': true, 'toezichthouder': true });
    }

    match /objects/{objectId} {
        allow get, list: if isSignedIn();
        allow create: if hasPermission('objects', 'create');
        allow update: if hasPermission('objects', 'edit');
        allow delete: if hasPermission('objects', 'delete');
    }

    match /meldingen/{meldingId} {
        allow read, write: if isSignedIn();
    }
    
    match /prullenbakken/{prullenbakId} {
      allow get, list: if isSignedIn();
      allow create: if hasPermission('prullenbakken', 'create');
      allow update: if hasPermission('prullenbakken', 'edit');
      allow delete: if hasPermission('prullenbakken', 'delete');
    }

    match /voertuigen/{vehicleId} {
      allow get, list: if isSignedIn();
      allow create: if hasPermission('vehicles', 'create');
      allow update: if hasPermission('vehicles', 'edit');
      allow delete: if hasPermission('vehicles', 'delete');

      match /{subcollection}/{docId} {
        allow read, write: if hasPermission('vehicles', 'edit');
      }
    }

    match /machines/{machineId} {
      allow get, list: if isSignedIn();
      allow create: if hasPermission('vehicles', 'create');
      allow update: if hasPermission('vehicles', 'edit');
      allow delete: if hasPermission('vehicles', 'delete');

      match /{subcollection}/{docId} {
        allow read, write: if hasPermission('vehicles', 'edit');
      }
    }
    
     // Legacy collections, deny all access for now.
    match /users/{userId}/{subcollection}/{docId} {
        allow read, write: if false;
    }
  }
}
