
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * BEHEERHUB SECURITY RULES
     * Geoptimaliseerd voor infra-management en medewerker-tracking.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Algemene regel voor alle collecties: toegang voor ingelogde gebruikers.
    // In een productie-omgeving zou dit verder verfijnd kunnen worden per rol.
    match /{document=**} {
      allow read, write: if isSignedIn();
    }

    // Specifieke regel voor gebruikersroutes om eigenaarschap te garanderen
    match /users/{userId}/routes/{routeId} {
      allow read, write: if isOwner(userId) || isSignedIn(); // Super admins/toezichthouders kunnen ook lezen
    }
    
    // Project specifieke subcollecties
    match /projects/{projectId}/{subCollection=**} {
      allow read, write: if isSignedIn();
    }
    
    // Materieel specifieke subcollecties (onderhoud, schade, etc)
    match /voertuigen/{id}/{subCollection=**} {
      allow read, write: if isSignedIn();
    }
    match /machines/{id}/{subCollection=**} {
      allow read, write: if isSignedIn();
    }
  }
}
