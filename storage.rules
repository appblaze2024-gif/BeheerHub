rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // Volledige toegang voor alle ingelogde gebruikers.
    // Dit garandeert dat zowel Super admins als de kiosk-accounts (NFC)
    // bestanden kunnen uploaden in alle mappen, inclusief settings/
    match /{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}