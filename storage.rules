rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    /**
     * BEHEERHUB STORAGE RULES
     * Toegankelijk voor alle ingelogde gebruikers.
     */
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Specifieke toegang voor instellingen en iconen
    match /settings/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}