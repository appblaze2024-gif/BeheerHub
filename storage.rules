rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Sta leesbewerkingen toe voor alle bestanden. Dit is nodig zodat de app 
    // de geüploade bestanden kan weergeven. In een productie-app zou je dit 
    // wellicht verder willen beveiligen.
    match /{allPaths=**} {
      allow read;
    }

    // Beveilig de 'projects' map specifiek.
    // Alleen een ingelogde gebruiker (request.auth != null) mag bestanden schrijven (uploaden).
    match /projects/{projectId}/{fileName} {
      allow write: if request.auth != null;
    }

    // Beveilig de 'damages' map specifiek.
    // Alleen een ingelogde gebruiker (request.auth != null) mag bestanden schrijven (uploaden).
    match /damages/{vehicleId}/{damageId}/{fileName} {
      allow write: if request.auth != null;
    }
    
    // Voeg een regel toe om het uploaden van voertuigafbeeldingen toe te staan
    // voor ingelogde gebruikers.
    match /vehicles/{vehicleId}/main_image/{fileName} {
      allow write: if request.auth != null;
    }

    // Voeg een regel toe om het uploaden van documenten toe te staan
    // voor ingelogde gebruikers.
    match /documents/{vehicleId}/{documentId}/{fileName} {
      allow write: if request.auth != null;
    }
  }
}
