
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    /**
     * BEHEERHUB STORAGE RULES
     * Toegankelijk voor alle ingelogde gebruikers (inclusief kiosk-accounts).
     * Nodig voor AI training, mail bijlages en schade foto's.
     */
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Expliciete toegang tot instellingen voor AI training
    match /settings/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Expliciete toegang tot meldingen voor doorzetting vanuit mail
    match /meldingen/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
