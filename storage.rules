rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // Voor ontwikkeling en wegens het gebruik van een gedeeld kiosk-account voor NFC,
    // staan we schrijven toe voor alle geauthenticeerde gebruikers.
    match /{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}