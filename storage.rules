rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // This function checks for user permissions by reading the user's profile from Firestore.
    // It's used to ensure that storage operations are only performed by authorized users,
    // mirroring the logic in firestore.rules.
    function hasPermission(module, action) {
      if (!isSignedIn()) {
        return false;
      }
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));

      if (!userDoc.exists) {
        return false;
      }
      if (userDoc.data.role == 'Super admin') {
        return true;
      }
      
      // Securely check nested properties for permissions.
      return userDoc.data.permissions != null &&
             module in userDoc.data.permissions &&
             userDoc.data.permissions[module] != null &&
             action in userDoc.data.permissions[module] &&
             userDoc.data.permissions[module][action] == true;
    }

    // Allow read operations for all authenticated users.
    // For a production app, you might want more granular read rules.
    match /{allPaths=**} {
      allow read: if isSignedIn();
    }
    
    // --- WRITE RULES ---

    // Rule for general project files (e.g., in the 'Bestanden' tab)
    match /projects/{projectId}/bestanden/{allPaths=**} {
        allow write: if hasPermission('projects', 'edit');
    }
    
    // Rule for 'Besteksmeldingen' photos.
    // This allows users who can create or edit spec reports to upload files.
    match /projects/{projectId}/besteksmeldingen/{meldingId}/{allPaths=**} {
      allow write: if hasPermission('specReports', 'create') || hasPermission('specReports', 'edit');
    }

    // Rule for public issue reports ('meldingen') photos
    match /meldingen/{meldingId}/{allPaths=**} {
        allow write: if isSignedIn();
    }

    // Rules for vehicle/machine images and documents
    match /voertuigen/{vehicleId}/{allPaths=**} {
      allow write: if hasPermission('vehicles', 'edit');
    }
    
    match /machines/{machineId}/{allPaths=**} {
      allow write: if hasPermission('vehicles', 'edit');
    }
    
    match /damages/{materieelId}/{allPaths=**} {
      allow write: if hasPermission('vehicles', 'edit');
    }
    
    match /documents/{materieelId}/{allPaths=**} {
      allow write: if hasPermission('vehicles', 'edit');
    }
  }
}
