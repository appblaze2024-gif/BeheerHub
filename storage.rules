rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // Volledige toegang voor alle ingelogde gebruikers om de unauthorised errors definitief op te lossen.
    // Dit geldt voor zowel Super admins als kiosk-accounts die via NFC inloggen.
    match /{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}