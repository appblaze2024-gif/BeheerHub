rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // Allow read operations for all authenticated users.
    match /{allPaths=**} {
      allow read: if isSignedIn();
    }
    
    // --- WRITE RULES ---
    
    // Rule for AI training samples - Explicitly allowed for all signed in users
    match /settings/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Rule for 'Besteksmeldingen' photos.
    match /projects/{projectId}/besteksmeldingen/{meldingId}/{allPaths=**} {
      allow write: if isSignedIn();
    }

    // Rule for 'Schouwingen' photos.
    match /projects/{projectId}/schouwingen/{schouwId}/{allPaths=**} {
      allow write: if isSignedIn();
    }

    // Rule for general project files (e.g., in the 'Bestanden' tab)
    match /projects/{projectId}/bestanden/{allPaths=**} {
        allow write: if isSignedIn();
    }
    
    // Rule for public issue reports ('meldingen') photos
    match /meldingen/{meldingId}/{allPaths=**} {
        allow write: if isSignedIn();
    }

    // Rules for vehicle/machine images and documents
    match /voertuigen/{vehicleId}/{allPaths=**} {
      allow write: if isSignedIn();
    }
    
    match /machines/{machineId}/{allPaths=**} {
      allow write: if isSignedIn();
    }
    
    match /damages/{materieelId}/{allPaths=**} {
      allow write: if isSignedIn();
    }
    
    match /documents/{materieelId}/{allPaths=**} {
      allow write: if isSignedIn();
    }
  }
}