
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Gebruikersprofiel binnen BeheerHub met rollen en permissies.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["Super admin", "toezichthouder", "ondersteuner", "medewerkers"] },
        "status": { "type": "string" },
        "wijk": { "type": "string" },
        "veegroute": { "type": "string" },
        "prullenbakkenroute": { "type": "string" },
        "nfcTagId": { "type": "string" },
        "lastSelectedProjectId": { "type": "string" },
        "permissions": { "type": "object" },
        "schouwenGemeente": { "type": "string" },
        "schouwenMapStyle": { "type": "string" },
        "lastUsedDienstColor": { "type": "string" }
      },
      "required": ["id", "email", "role"]
    },
    "Message": {
      "title": "Message",
      "description": "Bericht of notificatie tussen gebruikers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fromUserId": { "type": "string" },
        "fromName": { "type": "string" },
        "toUserId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["fromUserId", "toUserId", "content", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "Beheer van infra- en reinigingsprojecten.",
      "type": "object",
      "properties": {
        "projectnummer": { "type": "string" },
        "projectnaam": { "type": "string" },
        "locatie": { "type": "string" },
        "opdrachtgever": { "type": "string" },
        "startdatum": { "type": "string" },
        "einddatum": { "type": "string" },
        "bestek": { "type": "string" },
        "besteknummer": { "type": "string" },
        "versie": { "type": "string" },
        "datum": { "type": "string" },
        "omschrijving": { "type": "string" },
        "materieelIds": { "type": "array", "items": { "type": "string" } },
        "vehicleAvailability": { "type": "object" },
        "wijken": { "type": "array" },
        "veegroutes": { "type": "array" },
        "prullenbakkenroutes": { "type": "array" }
      },
      "required": ["projectnummer", "projectnaam"]
    },
    "AnnualPlanningItem": {
      "title": "AnnualPlanningItem",
      "description": "Planning van inzet (uren) per machine of medewerker voor een heel jaar.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "resourceName": { "type": "string" },
        "category": { "type": "string" },
        "year": { "type": "number" },
        "weeks": { "type": "object", "description": "Mapping van weeknummer (1-52) naar uren of waardes." },
        "color": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["resourceName", "year", "projectId"]
    },
    "AnnualMilestone": {
      "title": "AnnualMilestone",
      "description": "Speciale gebeurtenissen of projectfases in een specifieke week.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "weekNumber": { "type": "number" },
        "label": { "type": "string" },
        "year": { "type": "number" },
        "color": { "type": "string" },
        "borderLeft": { "type": "boolean" },
        "borderRight": { "type": "boolean" }
      },
      "required": ["weekNumber", "label", "year", "projectId"]
    },
    "AnnualPlanningConfig": {
      "title": "AnnualPlanningConfig",
      "description": "Instellingen per jaarplanning, zoals de weergavetitel.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "year": { "type": "number" },
        "title": { "type": "string" },
        "tableTitle": { "type": "string" }
      },
      "required": ["projectId", "year", "title"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Gebruikersprofielen."
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Ontvangen berichten per gebruiker."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Projectgegevens."
    },
    "/annual_planning/{itemId}": {
      "schema": { "$ref": "#/entities/AnnualPlanningItem" },
      "description": "Jaarplanning items."
    },
    "/annual_milestones/{milestoneId}": {
      "schema": { "$ref": "#/entities/AnnualMilestone" },
      "description": "Milestones per jaar."
    },
    "/annual_planning_configs/{configId}": {
      "schema": { "$ref": "#/entities/AnnualPlanningConfig" },
      "description": "Configuratie (zoals titels) voor jaarplanningen."
    }
  }
}
