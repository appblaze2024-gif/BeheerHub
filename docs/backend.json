
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Gebruikersprofiel binnen BeheerHub met rollen en permissies.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["Super admin", "toezichthouder", "ondersteuner", "medewerkers"] },
        "status": { "type": "string" },
        "wijk": { "type": "string" },
        "veegroute": { "type": "string" },
        "prullenbakkenroute": { "type": "string" },
        "nfcTagId": { "type": "string" },
        "lastSelectedProjectId": { "type": "string" },
        "permissions": { "type": "object" },
        "schouwenGemeente": { "type": "string" },
        "schouwenMapStyle": { "type": "string" },
        "lastUsedDienstColor": { "type": "string" }
      },
      "required": ["id", "email", "role"]
    },
    "Project": {
      "title": "Project",
      "description": "Beheer van infra- en reinigingsprojecten.",
      "type": "object",
      "properties": {
        "projectnummer": { "type": "string" },
        "projectnaam": { "type": "string" },
        "locatie": { "type": "string" },
        "opdrachtgever": { "type": "string" },
        "startdatum": { "type": "string" },
        "einddatum": { "type": "string" },
        "bestek": { "type": "string" },
        "besteknummer": { "type": "string" },
        "versie": { "type": "string" },
        "datum": { "type": "string" },
        "omschrijving": { "type": "string" },
        "materieelIds": { "type": "array", "items": { "type": "string" } },
        "vehicleAvailability": { "type": "object" },
        "wijken": { "type": "array" },
        "veegroutes": { "type": "array" },
        "prullenbakkenroutes": { "type": "array" }
      },
      "required": ["projectnummer", "projectnaam"]
    },
    "Medewerker": {
      "title": "Medewerker",
      "description": "Personeelsgegevens en werkroosters.",
      "type": "object",
      "properties": {
        "voornaam": { "type": "string" },
        "tussenvoegsel": { "type": "string" },
        "achternaam": { "type": "string" },
        "functie": { "type": "string" },
        "status": { "type": "string" },
        "planningOrder": { "type": "number" },
        "urenPerDag": { "type": "object" },
        "avatarUrl": { "type": "string" },
        "personeelsnummer": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "Melding": {
      "title": "Melding",
      "description": "Meldingen openbare ruimte en werkbonnen.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "intakenummer": { "type": "string" },
        "status": { "type": "string" },
        "hoofdcategorie": { "type": "string" },
        "subcategorie": { "type": "string" },
        "datum": { "type": "string" },
        "tijdstip": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "extra_informatie": { "type": "string" },
        "straatnaam": { "type": "string" },
        "huisnummer": { "type": "string" },
        "plaats": { "type": "string" },
        "wijk": { "type": "string" },
        "melder": { "type": "string" },
        "files": { "type": "array" },
        "fotos": { "type": "array" },
        "afhandeling_fotos": { "type": "array" },
        "tasks": { "type": "array" },
        "hoeveelheden": { "type": "array" },
        "gewerkteMinuten": { "type": "number" },
        "workStartedAt": { "type": "string" }
      }
    },
    "Route": {
      "title": "Route",
      "description": "Gereden ritten door medewerkers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "projectId": { "type": "string" },
        "routeName": { "type": "string" },
        "date": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "completedObjects": { "type": "array", "items": { "type": "string" } },
        "skippedObjects": { "type": "array", "items": { "type": "string" } },
        "totalObjects": { "type": "number" }
      }
    },
    "Sensor": {
      "title": "Sensor",
      "description": "IoT sensor data voor vulgraden.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "vulgraad": { "type": "number" },
        "status": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "currentDistanceCm": { "type": "number" },
        "binDepthCm": { "type": "number" },
        "measurementFrequency": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Gebruikersprofielen."
    },
    "/users/{userId}/routes/{routeId}": {
      "schema": { "$ref": "#/entities/Route" },
      "description": "Gereden ritten per gebruiker."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Projectgegevens."
    },
    "/projects/{projectId}/diensten/{dienstId}": {
      "description": "Ingeplande diensten op projecten."
    },
    "/projects/{projectId}/bestanden/{bestandId}": {
      "description": "Bestanden gekoppeld aan projecten."
    },
    "/projects/{projectId}/folders/{folderId}": {
      "description": "Mappenstructuur voor projectbestanden."
    },
    "/projects/{projectId}/besteksmeldingen/{meldingId}": {
      "description": "Besteksmeldingen per project."
    },
    "/medewerkers/{medewerkerId}": {
      "schema": { "$ref": "#/entities/Medewerker" },
      "description": "Personeelsbestand."
    },
    "/meldingen/{meldingId}": {
      "schema": { "$ref": "#/entities/Melding" },
      "description": "Meldingen en werkbonnen."
    },
    "/sensors/{sensorId}": {
      "schema": { "$ref": "#/entities/Sensor" },
      "description": "IoT sensoren."
    },
    "/voertuigen/{voertuigId}": {
      "description": "Wagenpark."
    },
    "/machines/{machineId}": {
      "description": "Machinepark."
    },
    "/objects/{objectId}": {
      "description": "Areaal objecten."
    },
    "/settings/{settingId}": {
      "description": "Systeeminstellingen (statussen, categorieën, etc.)"
    }
  }
}
