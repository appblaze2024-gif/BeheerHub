{
  "entities": {
    "Route": {
      "title": "Route",
      "type": "object",
      "description": "Represents a user-driven route history.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "projectId": { "type": "string" },
        "originalRouteId": { "type": "string" },
        "routeName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "allObjectIds": { "type": "array", "items": { "type": "string" } },
        "completedObjects": { "type": "array", "items": { "type": "string" } },
        "skippedObjects": { "type": "array", "items": { "type": "string" } },
        "totalObjects": { "type": "number" }
      },
      "required": ["userId", "projectId", "originalRouteId", "routeName", "date", "startTime"]
    },
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "type": "object",
      "description": "Represents a project.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the project."
        },
        "projectnummer": {
          "type": "string"
        },
        "projectnaam": {
          "type": "string"
        },
        "locatie": {
          "type": "string"
        },
        "opdrachtgever": {
          "type": "string"
        },
        "startdatum": {
          "type": "string",
          "format": "date"
        },
        "einddatum": {
          "type": "string",
          "format": "date"
        },
        "bestek": {
          "type": "string"
        },
        "besteknummer": {
          "type": "string"
        },
        "versie": {
          "type": "string"
        },
        "datum": {
          "type": "string",
          "format": "date"
        },
        "omschrijving": {
          "type": "string"
        },
        "werksoorten": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "postnummer": {
                "type": "string"
              },
              "werksoort": {
                "type": "string"
              },
              "eenheid": {
                "type": "string"
              },
              "fictieveH": {
                "type": "string"
              },
              "uurprijs": {
                "type": "string"
              }
            }
          }
        },
        "wijken": {
          "type": "array",
          "items": {
            "$ref": "#/backend/entities/Wijk"
          }
        },
        "veegroutes": {
          "type": "array",
          "items": {
            "$ref": "#/backend/entities/Veegroute"
          }
        },
        "prullenbakkenroutes": {
            "type": "array",
            "items": {
                "$ref": "#/backend/entities/Prullenbakkenroute"
            }
        }
      },
      "required": [
        "projectnummer",
        "projectnaam"
      ]
    },
    "Wijk": {
        "title": "Wijk",
        "type": "object",
        "description": "Represents a district within a project.",
        "properties": {
            "id": { "type": "string" },
            "naam": { "type": "string" },
            "locatie": { "type": "string" },
            "subGebieden": { "type": "string" }
        },
        "required": ["naam"]
    },
    "Veegroute": {
        "title": "Veegroute",
        "type": "object",
        "description": "Represents a sweeping route within a project.",
        "properties": {
            "id": { "type": "string" },
            "naam": { "type": "string" },
            "locatie": { "type": "string" },
            "subGebieden": { "type": "string" }
        },
        "required": ["naam"]
    },
    "Prullenbakkenroute": {
        "title": "Prullenbakkenroute",
        "type": "object",
        "description": "Represents a trash can route within a project.",
        "properties": {
            "id": { "type": "string" },
            "naam": { "type": "string" },
            "locatie": { "type": "string" },
            "subGebieden": { "type": "string" }
        },
        "required": ["naam"]
    },
    "Boekingregel": {
        "title": "Boekingregel",
        "type": "object",
        "description": "Represents an internal booking rule for work planning.",
        "properties": {
            "id": { "type": "string" },
            "naam": { "type": "string" }
        },
        "required": ["naam"]
    },
     "Object": {
      "title": "Object",
      "type": "object",
      "description": "Represents a physical object in the world.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the object." },
        "latitude": { "type": "number", "description": "The latitude coordinate of the object." },
        "longitude": { "type": "number", "description": "The longitude coordinate of the object." },
        "locatieType": { "type": "string" },
        "locatieSubType": { "type": "string" },
        "kwaliteit": { "type": "string" },
        "isActief": { "type": "boolean" },
        "straatnaam": { "type": "string" },
        "huisnummer": { "type": "string" },
        "waarschuwing": { "type": "string" },
        "vulgraad": { "type": "number" },
        "locatieWerkgebieden": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "latitude", "longitude"]
    },
    "Bestand": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Bestand",
      "type": "object",
      "description": "Represents a file with its metadata.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "size": {
          "type": "number"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "uploadedAt": {
          "type": "string",
          "format": "date-time"
        },
        "storagePath": {
          "type": "string"
        }
      }
    },
    "Revenue": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Revenue",
      "type": "object",
      "description": "Represents a single revenue stream.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the revenue entry."
        },
        "date": {
          "type": "string",
          "description": "Date the revenue was received.",
          "format": "date-time"
        },
        "amount": {
          "type": "number",
          "description": "The amount of revenue received."
        },
        "description": {
          "type": "string",
          "description": "Description of the revenue source."
        }
      },
      "required": [
        "id",
        "date",
        "amount"
      ]
    },
    "Expense": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Expense",
      "type": "object",
      "description": "Represents a single expense.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the expense entry."
        },
        "date": {
          "type": "string",
          "description": "Date the expense was incurred.",
          "format": "date-time"
        },
        "amount": {
          "type": "number",
          "description": "The amount of the expense."
        },
        "description": {
          "type": "string",
          "description": "Description of the expense."
        }
      },
      "required": [
        "id",
        "date",
        "amount"
      ]
    },
    "Appointment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Appointment",
      "type": "object",
      "description": "Represents a scheduled appointment.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the appointment."
        },
        "onderwerp": {
          "type": "string",
          "description": "Subject of the appointment."
        },
        "datum": {
          "type": "string",
          "format": "date",
          "description": "Date of the appointment."
        },
        "tijd": {
          "type": "string",
          "format": "time",
          "description": "Time of the appointment."
        },
        "notities": {
          "type": "string",
          "description": "Notes for the appointment."
        }
      },
      "required": [
        "id",
        "onderwerp",
        "datum",
        "tijd"
      ]
    },
    "OrganisatieContact": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "OrganisatieContact",
      "type": "object",
      "description": "Represents a contact person in the organization for a project.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the contact."
        },
        "naam": {
          "type": "string",
          "description": "Name of the contact person."
        },
        "rol": {
          "type": "string",
          "description": "Role of the contact person in the project."
        },
        "bedrijf": {
          "type": "string",
          "description": "Company of the contact person."
        },
        "telefoon": {
          "type": "string",
          "description": "Phone number of the contact person."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the contact person."
        },
        "wijk": {
          "type": "string",
          "description": "The district the contact is associated with."
        }
      },
      "required": [
        "id",
        "naam",
        "rol"
      ]
    },
    "Medewerker": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Medewerker",
      "type": "object",
      "description": "Represents an employee in the system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the employee."
        },
        "voornaam": {
          "type": "string",
          "description": "First name of the employee."
        },
        "tussenvoegsel": {
          "type": "string",
          "description": "Middle name prefix of the employee."
        },
        "achternaam": {
          "type": "string",
          "description": "Last name of the employee."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the employee."
        },
        "telefoonnummer": {
          "type": "string",
          "description": "Phone number of the employee."
        },
        "mobiel": {
            "type": "string"
        },
        "noodnummer": {
            "type": "string"
        },
        "geboortedatum": {
            "type": "string",
            "format": "date"
        },
        "geboorteplaats": {
            "type": "string"
        },
        "nationaliteit": {
            "type": "string"
        },
        "bsn": {
            "type": "string"
        },
        "adres": {
            "type": "string"
        },
        "postcode": {
            "type": "string"
        },
        "plaats": {
            "type": "string"
        },
        "paspoortnummer": {
            "type": "string"
        },
        "bankrekening": {
            "type": "string"
        },
        "personeelsnummer": {
            "type": "string"
        },
        "taal": {
          "type": "string",
          "description": "Preferred language of the employee."
        },
        "functie": {
          "type": "string",
          "description": "Job title of the employee."
        },
        "status": {
          "type": "string",
          "description": "Current status of the employee (e.g., 'Actief', 'Inactief').",
          "enum": ["Actief", "Inactief", "Niet uitgenodigd"]
        },
        "avatarUrl": {
          "type": "string",
          "format": "uri",
          "description": "URL of the employee's avatar image."
        }
      },
      "required": ["voornaam", "achternaam"]
    },
     "Dienst": {
      "title": "Dienst",
      "type": "object",
      "description": "Represents a single shift or service for an employee on a project.",
      "properties": {
        "id": { "type": "string" },
        "medewerkerId": { "type": "string" },
        "projectId": { "type": "string" },
        "werksoort": { "type": "string" },
        "boekingregelId": { "type": "string" },
        "starttijd": { "type": "string", "format": "time" },
        "eindtijd": { "type": "string", "format": "time" },
        "datum": { "type": "string", "format": "date" },
        "onbetaaldePauze": { "type": "number", "description": "Unpaid break in minutes." },
        "verbergEindtijd": { "type": "boolean" },
        "herhaalDienst": { "type": "boolean" },
        "goedkeuringVereist": { "type": "boolean" },
        "informeerMedewerkers": { "type": "boolean" },
        "voertuigId": { "type": ["string", "null"] }
      },
      "required": ["medewerkerId", "projectId", "boekingregelId", "starttijd", "eindtijd", "datum"]
    },
    "Melding": {
      "title": "Melding",
      "type": "object",
      "description": "Represents an issue or report (melding).",
      "properties": {
        "id": { "type": "string" },
        "intakenummer": { "type": "string" },
        "datum": { "type": "string", "format": "date" },
        "tijdstip": { "type": "string", "format": "time" },
        "melder": { "type": "string" },
        "aangenomen_door": { "type": "string" },
        "extern_meldingsnummer": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "hoofdcategorie": { "type": "string" },
        "subcategorie": { "type": "string" },
        "straatnaam": { "type": "string" },
        "postcode": { "type": "string" },
        "plaats": { "type": "string" },
        "wijk": { "type": "string" },
        "extra_informatie": { "type": "string" },
        "status": {
          "type": "string",
          "enum": [
            "Nieuw",
            "Intern doorgezet",
            "In behandeling",
            "Gepland op korte termijn",
            "Gepland op langere termijn",
            "Dubbel gemeld",
            "Afgerond",
            "Niet in beheer"
          ]
        },
        "afhandeling_datum": { "type": "string", "format": "date" },
        "afgehandeld_door": { "type": "string" },
        "afhandeling_bijzonderheden": { "type": "string" }
      },
      "required": ["id", "intakenummer", "datum", "tijdstip", "latitude", "longitude", "status", "hoofdcategorie", "subcategorie"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile and display preferences.",
      "properties": {
        "id": {
          "type": "string",
          "description": "The user's unique ID, same as their auth UID."
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "displayName": {
          "type": "string"
        },
        "sidebarCollapsed": {
          "type": "boolean",
          "description": "User's preference for the sidebar state."
        },
        "mailSettings": {
          "type": "object",
          "description": "User's settings for their external mail account.",
          "properties": {
            "incoming": {
              "type": "object",
              "properties": {
                "server": {
                  "type": "string"
                },
                "port": {
                  "type": "number"
                },
                "user": {
                  "type": "string"
                },
                "password": {
                  "type": "string"
                },
                "security": {
                  "type": "string",
                  "enum": [
                    "SSL/TLS",
                    "STARTTLS",
                    "None"
                  ]
                }
              }
            },
            "outgoing": {
              "type": "object",
              "properties": {
                "server": {
                  "type": "string"
                },
                "port": {
                  "type": "number"
                },
                "user": {
                  "type": "string"
                },
                "password": {
                  "type": "string"
                },
                "security": {
                  "type": "string",
                  "enum": [
                    "SSL/TLS",
                    "STARTTLS",
                    "None"
                  ]
                }
              }
            }
          }
        }
      },
      "required": [
        "id"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores user-specific profile data and preferences.",
          "params": [
            {
              "name": "userId",
              "description": "The ID of the user."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/routes/{routeId}",
        "definition": {
            "entityName": "Route",
            "schema": { "$ref": "#/backend/entities/Route" },
            "description": "Stores user-specific route history.",
            "params": [
                { "name": "userId", "description": "The ID of the user." },
                { "name": "routeId", "description": "The ID of the route history entry." }
            ]
        }
      },
      {
        "path": "/projects/{projectId}",
        "definition": {
          "entityName": "Project",
          "schema": {
            "$ref": "#/backend/entities/Project"
          },
          "description": "Stores all projects for the application.",
          "params": [
            {
              "name": "projectId",
              "description": "The ID of the project."
            }
          ]
        }
      },
       {
        "path": "/projects/{projectId}/diensten/{dienstId}",
        "definition": {
          "entityName": "Dienst",
          "schema": { "$ref": "#/backend/entities/Dienst" },
          "description": "Stores all shifts for a specific project.",
          "params": [
            { "name": "projectId", "description": "The ID of the project." },
            { "name": "dienstId", "description": "The ID of the shift." }
          ]
        }
      },
      {
        "path": "/projects/{projectId}/boekingregels/{boekingregelId}",
        "definition": {
          "entityName": "Boekingregel",
          "schema": { "$ref": "#/backend/entities/Boekingregel" },
          "description": "Stores all booking rules for a specific project.",
          "params": [
            { "name": "projectId", "description": "The ID of the project." },
            { "name": "boekingregelId", "description": "The ID of the booking rule." }
          ]
        }
      },
      {
        "path": "/projects/{projectId}/bestanden/{bestandId}",
        "definition": {
          "entityName": "Bestand",
          "schema": {
            "$ref": "#/backend/entities/Bestand"
          },
          "description": "Stores files for a specific project.",
          "params": [
            {
              "name": "projectId",
              "description": "The ID of the project."
            },
            {
              "name": "bestandId",
              "description": "The ID of the file."
            }
          ]
        }
      },
      {
        "path": "/projects/{projectId}/afspraken/{afspraakId}",
        "definition": {
          "entityName": "Appointment",
          "schema": {
            "$ref": "#/backend/entities/Appointment"
          },
          "description": "Stores appointments for a specific project.",
          "params": [
            {
              "name": "projectId",
              "description": "The ID of the project."
            },
            {
              "name": "afspraakId",
              "description": "The ID of the appointment."
            }
          ]
        }
      },
      {
        "path": "/projects/{projectId}/organisatie/{contactId}",
        "definition": {
          "entityName": "OrganisatieContact",
          "schema": {
            "$ref": "#/backend/entities/OrganisatieContact"
          },
          "description": "Stores contact persons for a specific project.",
          "params": [
            {
              "name": "projectId",
              "description": "The ID of the project."
            },
            {
              "name": "contactId",
              "description": "The ID of the contact."
            }
          ]
        }
      },
      {
        "path": "/medewerkers/{medewerkerId}",
        "definition": {
            "entityName": "Medewerker",
            "schema": { "$ref": "#/backend/entities/Medewerker" },
            "description": "Stores all employees for the application.",
            "params": [
                { "name": "medewerkerId", "description": "The ID of the employee." }
            ]
        }
      },
      {
        "path": "/objects/{objectId}",
        "definition": {
          "entityName": "Object",
          "schema": { "$ref": "#/backend/entities/Object" },
          "description": "Stores all physical objects for the application.",
          "params": [
            { "name": "objectId", "description": "The ID of the object." }
          ]
        }
      },
      {
        "path": "/meldingen/{meldingId}",
        "definition": {
          "entityName": "Melding",
          "schema": { "$ref": "#/backend/entities/Melding" },
          "description": "Stores all issues/reports for the application.",
          "params": [
            { "name": "meldingId", "description": "The ID of the issue." }
          ]
        }
      },
      {
        "path": "/users/{userId}/revenues/{revenueId}",
        "definition": {
          "entityName": "Revenue",
          "schema": {
            "$ref": "#/backend/entities/Revenue"
          },
          "description": "Stores revenue data for a specific user. Path-based ownership ensures only the user can access their revenue data.",
          "params": [
            {
              "name": "userId",
              "description": "The ID of the user who owns the revenue data."
            },
            {
              "name": "revenueId",
              "description": "The ID of the revenue entry."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/expenses/{expenseId}",
        "definition": {
          "entityName": "Expense",
          "schema": {
            "$ref": "#/backend/entities/Expense"
          },
          "description": "Stores expense data for a specific user. Path-based ownership ensures only the user can access their expense data.",
          "params": [
            {
              "name": "userId",
              "description": "The ID of the user who owns the expense data."
            },
            {
              "name": "expenseId",
              "description": "The ID of the expense entry."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/appointments/{appointmentId}",
        "definition": {
          "entityName": "Appointment",
          "schema": {
            "$ref": "#/backend/entities/Appointment"
          },
          "description": "Stores appointment data for a specific user. Path-based ownership ensures only the user can access their appointment data.",
          "params": [
            {
              "name": "userId",
              "description": "The ID of the user who owns the appointment data."
            },
            {
              "name": "appointmentId",
              "description": "The ID of the appointment entry."
            }
          ]
        }
      }
    ],
    "reasoning": "The Firestore structure is designed to provide a secure and scalable foundation for the BizBoard application, focusing on clear ownership and authorization. Each user's data (revenues, expenses, and appointments) is stored under their respective user ID, ensuring data isolation and simplified security rules. This design avoids complex queries and `get()` calls in security rules, which aligns with the principles of Authorization Independence and facilitates easier debugging. The use of path-based ownership `/users/{userId}/revenues/{revenueId}` makes it straightforward to implement security rules that grant access only to the owner of the data.\n\n*   **Authorization Independence:** Achieved by structuring data under user-specific paths, eliminating the need for `get()` calls to parent documents for authorization. All data needed for authorization is implicitly available in the path.\n*   **QAPs:** Secure list operations are supported by the path-based ownership model. Listing revenues, expenses, or appointments is always scoped to a specific user, preventing unauthorized access to other users' data.\n\nBy adhering to these principles, the data structure promotes a maintainable and secure application."
  }
}
