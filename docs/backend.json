
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Gebruikersprofiel binnen BeheerHub met rollen en permissies.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["Super admin", "toezichthouder", "ondersteuner", "medewerkers"] },
        "status": { "type": "string" },
        "wijk": { "type": "string" },
        "veegroute": { "type": "string" },
        "prullenbakkenroute": { "type": "string" },
        "nfcTagId": { "type": "string" },
        "lastSelectedProjectId": { "type": "string" },
        "permissions": { "type": "object" },
        "schouwenGemeente": { "type": "string" },
        "schouwenMapStyle": { "type": "string" },
        "lastUsedDienstColor": { "type": "string" }
      },
      "required": ["id", "email", "role"]
    },
    "GisFolder": {
      "title": "GisFolder",
      "description": "Een map om GIS-lagen in te organiseren.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "parentId": { "type": "string", "description": "ID van de bovenliggende map (of null voor root)." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "GisLayer": {
      "title": "GisLayer",
      "description": "Een geografische kaartlaag geüpload door de gebruiker.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "folderId": { "type": "string", "description": "ID van de map waarin deze laag staat (of null voor root)." },
        "data": { "type": "string", "description": "Geserialiseerde GeoJSON data van de laag." },
        "visible": { "type": "boolean" },
        "color": { "type": "string" },
        "type": { "type": "string", "enum": ["fill", "line", "circle"] },
        "lineWidth": { "type": "number" },
        "lineStyle": { "type": "string", "enum": ["solid", "dashed", "dotted"] },
        "icon": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "data", "visible", "color", "type", "createdAt"]
    },
    "SharedMap": {
      "title": "SharedMap",
      "description": "Een configuratie van de kaart die gedeeld is met anderen.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "viewState": { "type": "object" },
        "visibleLayerIds": { "type": "array", "items": { "type": "string" } },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "viewState", "visibleLayerIds", "creatorId", "createdAt"]
    },
    "UserFolder": {
      "title": "UserFolder",
      "description": "Een map aangemaakt door een gebruiker om taken in te organiseren.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "taskIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "taskIds", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Gebruikersprofielen."
    },
    "/users/{userId}/gisFolders/{folderId}": {
      "schema": { "$ref": "#/entities/GisFolder" },
      "description": "Mappen voor GIS-lagen."
    },
    "/users/{userId}/gisLayers/{layerId}": {
      "schema": { "$ref": "#/entities/GisLayer" },
      "description": "Geüploade GIS-lagen."
    },
    "/shared_maps/{mapId}": {
      "schema": { "$ref": "#/entities/SharedMap" },
      "description": "Gedeelde kaartconfiguraties."
    }
  }
}
