
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Gebruikersprofiel binnen BeheerHub met rollen en permissies.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["Super admin", "toezichthouder", "ondersteuner", "medewerkers"] },
        "status": { "type": "string" },
        "wijk": { "type": "string" },
        "veegroute": { "type": "string" },
        "prullenbakkenroute": { "type": "string" },
        "nfcTagId": { "type": "string" },
        "lastSelectedProjectId": { "type": "string" },
        "permissions": { "type": "object" },
        "schouwenGemeente": { "type": "string" },
        "schouwenMapStyle": { "type": "string" },
        "lastUsedDienstColor": { "type": "string" }
      },
      "required": ["id", "email", "role"]
    },
    "Message": {
      "title": "Message",
      "description": "Bericht of notificatie tussen gebruikers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fromUserId": { "type": "string" },
        "fromName": { "type": "string" },
        "toUserId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["fromUserId", "toUserId", "content", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "Beheer van infra- en reinigingsprojecten.",
      "type": "object",
      "properties": {
        "projectnummer": { "type": "string" },
        "projectnaam": { "type": "string" },
        "locatie": { "type": "string" },
        "opdrachtgever": { "type": "string" },
        "startdatum": { "type": "string" },
        "einddatum": { "type": "string" },
        "bestek": { "type": "string" },
        "besteknummer": { "type": "string" },
        "versie": { "type": "string" },
        "datum": { "type": "string" },
        "omschrijving": { "type": "string" },
        "materieelIds": { "type": "array", "items": { "type": "string" } },
        "vehicleAvailability": { "type": "object" },
        "wijken": { "type": "array" },
        "veegroutes": { "type": "array" },
        "prullenbakkenroutes": { "type": "array" }
      },
      "required": ["projectnummer", "projectnaam"]
    },
    "Medewerker": {
      "title": "Medewerker",
      "description": "Personeelsbestand gegevens.",
      "type": "object",
      "properties": {
        "voornaam": { "type": "string" },
        "tussenvoegsel": { "type": "string" },
        "achternaam": { "type": "string" },
        "functie": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Melding": {
      "title": "Melding",
      "description": "Meldingen openbare ruimte.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "intakenummer": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Sensor": {
      "title": "Sensor",
      "description": "IoT sensor data.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "vulgraad": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Gebruikersprofielen."
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Ontvangen berichten per gebruiker."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Projectgegevens."
    },
    "/medewerkers/{medewerkerId}": {
      "schema": { "$ref": "#/entities/Medewerker" },
      "description": "Personeelsbestand."
    },
    "/meldingen/{meldingId}": {
      "schema": { "$ref": "#/entities/Melding" },
      "description": "Meldingen en werkbonnen."
    },
    "/sensors/{sensorId}": {
      "schema": { "$ref": "#/entities/Sensor" },
      "description": "IoT sensoren."
    }
  }
}
