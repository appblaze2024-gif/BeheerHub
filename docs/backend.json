
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Gebruikersprofiel binnen BeheerHub met rollen en permissies.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["Super admin", "toezichthouder", "ondersteuner", "medewerkers"] },
        "status": { "type": "string" },
        "wijk": { "type": "string" },
        "nfcTagId": { "type": "string" },
        "lastSelectedProjectId": { "type": "string" }
      },
      "required": ["id", "email", "role"]
    },
    "Project": {
      "title": "Project",
      "description": "Beheer van infra- en reinigingsprojecten.",
      "type": "object",
      "properties": {
        "projectnummer": { "type": "string" },
        "projectnaam": { "type": "string" },
        "locatie": { "type": "string" },
        "opdrachtgever": { "type": "string" },
        "vehicleAvailability": { "type": "object" }
      },
      "required": ["projectnummer", "projectnaam"]
    },
    "Medewerker": {
      "title": "Medewerker",
      "description": "Personeelsgegevens en werkroosters.",
      "type": "object",
      "properties": {
        "voornaam": { "type": "string" },
        "achternaam": { "type": "string" },
        "functie": { "type": "string" },
        "status": { "type": "string" },
        "planningOrder": { "type": "number" }
      }
    },
    "Melding": {
      "title": "Melding",
      "description": "Meldingen openbare ruimte en werkbonnen.",
      "type": "object",
      "properties": {
        "intakenummer": { "type": "string" },
        "status": { "type": "string" },
        "hoofdcategorie": { "type": "string" },
        "subcategorie": { "type": "string" },
        "datum": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" }
      }
    },
    "Route": {
      "title": "Route",
      "description": "Gereden ritten door medewerkers.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "projectId": { "type": "string" },
        "routeName": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "completedObjects": { "type": "array", "items": { "type": "string" } },
        "skippedObjects": { "type": "array", "items": { "type": "string" } },
        "totalObjects": { "type": "number" }
      }
    },
    "Sensor": {
      "title": "Sensor",
      "description": "IoT sensor data voor vulgraden.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "vulgraad": { "type": "number" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "description": "Gebruikersprofielen."
        }
      },
      {
        "path": "/users/{userId}/routes/{routeId}",
        "definition": {
          "entityName": "Route",
          "description": "Gereden ritten per gebruiker."
        }
      },
      {
        "path": "/projects/{projectId}",
        "definition": {
          "entityName": "Project",
          "description": "Projectgegevens."
        }
      },
      {
        "path": "/medewerkers/{medewerkerId}",
        "definition": {
          "entityName": "Medewerker",
          "description": "Personeelsbestand."
        }
      },
      {
        "path": "/meldingen/{meldingId}",
        "definition": {
          "entityName": "Melding",
          "description": "Meldingen en werkbonnen."
        }
      },
      {
        "path": "/sensors/{sensorId}",
        "definition": {
          "entityName": "Sensor",
          "description": "IoT sensoren."
        }
      },
      {
        "path": "/voertuigen/{voertuigId}",
        "definition": {
          "description": "Wagenpark."
        }
      },
      {
        "path": "/machines/{machineId}",
        "definition": {
          "description": "Machinepark."
        }
      },
      {
        "path": "/objects/{objectId}",
        "definition": {
          "description": "Areaal objecten."
        }
      }
    ]
  }
}
