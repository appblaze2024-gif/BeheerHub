{
  "entities": {
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "type": "object",
      "description": "Represents a project.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the project."
        },
        "projectnummer": {
          "type": "string"
        },
        "projectnaam": {
          "type": "string"
        },
        "locatie": {
          "type": "string"
        },
        "opdrachtgever": {
          "type": "string"
        },
        "startdatum": {
          "type": "string",
          "format": "date"
        },
        "einddatum": {
          "type": "string",
          "format": "date"
        },
        "bestek": {
          "type": "string"
        },
        "besteknummer": {
          "type": "string"
        },
        "versie": {
          "type": "string"
        },
        "datum": {
          "type": "string",
          "format": "date"
        },
        "omschrijving": {
          "type": "string"
        },
        "werksoorten": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "postnummer": {
                "type": "string"
              },
              "werksoort": {
                "type": "string"
              },
              "eenheid": {
                "type": "string"
              },
              "fictieveH": {
                "type": "string"
              },
              "uurprijs": {
                "type": "string"
              }
            }
          }
        }
      },
      "required": ["projectnummer", "projectnaam"]
    },
    "Bestand": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Bestand",
      "type": "object",
      "description": "Represents a file with its metadata.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "size": {
          "type": "number"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "uploadedAt": {
          "type": "string",
          "format": "date-time"
        },
        "storagePath": {
          "type": "string"
        }
      }
    },
    "Revenue": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Revenue",
      "type": "object",
      "description": "Represents a single revenue stream.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the revenue entry."
        },
        "date": {
          "type": "string",
          "description": "Date the revenue was received.",
          "format": "date-time"
        },
        "amount": {
          "type": "number",
          "description": "The amount of revenue received."
        },
        "description": {
          "type": "string",
          "description": "Description of the revenue source."
        }
      },
      "required": [
        "id",
        "date",
        "amount"
      ]
    },
    "Expense": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Expense",
      "type": "object",
      "description": "Represents a single expense.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the expense entry."
        },
        "date": {
          "type": "string",
          "description": "Date the expense was incurred.",
          "format": "date-time"
        },
        "amount": {
          "type": "number",
          "description": "The amount of the expense."
        },
        "description": {
          "type": "string",
          "description": "Description of the expense."
        }
      },
      "required": [
        "id",
        "date",
        "amount"
      ]
    },
    "Appointment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Appointment",
      "type": "object",
      "description": "Represents a scheduled appointment.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the appointment."
        },
        "onderwerp": {
          "type": "string",
          "description": "Subject of the appointment."
        },
        "datum": {
          "type": "string",
          "format": "date",
          "description": "Date of the appointment."
        },
        "tijd": {
          "type": "string",
          "format": "time",
          "description": "Time of the appointment."
        },
        "notities": {
          "type": "string",
          "description": "Notes for the appointment."
        }
      },
      "required": [
        "id",
        "onderwerp",
        "datum",
        "tijd"
      ]
    },
    "OrganisatieContact": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "OrganisatieContact",
      "type": "object",
      "description": "Represents a contact person in the organization for a project.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the contact."
        },
        "naam": {
          "type": "string",
          "description": "Name of the contact person."
        },
        "rol": {
          "type": "string",
          "description": "Role of the contact person in the project."
        },
        "bedrijf": {
          "type": "string",
          "description": "Company of the contact person."
        },
        "telefoon": {
          "type": "string",
          "description": "Phone number of the contact person."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the contact person."
        }
      },
      "required": ["id", "naam", "rol"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/projects/{projectId}",
        "definition": {
          "entityName": "Project",
          "schema": {
            "$ref": "#/backend/entities/Project"
          },
          "description": "Stores all projects for the application.",
          "params": [
            {
              "name": "projectId",
              "description": "The ID of the project."
            }
          ]
        }
      },
       {
        "path": "/projects/{projectId}/bestanden/{bestandId}",
        "definition": {
          "entityName": "Bestand",
          "schema": {
            "$ref": "#/backend/entities/Bestand"
          },
          "description": "Stores files for a specific project.",
          "params": [
            {
              "name": "projectId",
              "description": "The ID of the project."
            },
            {
              "name": "bestandId",
              "description": "The ID of the file."
            }
          ]
        }
      },
      {
        "path": "/projects/{projectId}/afspraken/{afspraakId}",
        "definition": {
          "entityName": "Appointment",
          "schema": {
            "$ref": "#/backend/entities/Appointment"
          },
          "description": "Stores appointments for a specific project.",
          "params": [
            {
              "name": "projectId",
              "description": "The ID of the project."
            },
            {
              "name": "afspraakId",
              "description": "The ID of the appointment."
            }
          ]
        }
      },
      {
        "path": "/projects/{projectId}/organisatie/{contactId}",
        "definition": {
          "entityName": "OrganisatieContact",
          "schema": {
            "$ref": "#/backend/entities/OrganisatieContact"
          },
          "description": "Stores contact persons for a specific project.",
          "params": [
            {
              "name": "projectId",
              "description": "The ID of the project."
            },
            {
              "name": "contactId",
              "description": "The ID of the contact."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/revenues/{revenueId}",
        "definition": {
          "entityName": "Revenue",
          "schema": {
            "$ref": "#/backend/entities/Revenue"
          },
          "description": "Stores revenue data for a specific user. Path-based ownership ensures only the user can access their revenue data.",
          "params": [
            {
              "name": "userId",
              "description": "The ID of the user who owns the revenue data."
            },
            {
              "name": "revenueId",
              "description": "The ID of the revenue entry."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/expenses/{expenseId}",
        "definition": {
          "entityName": "Expense",
          "schema": {
            "$ref": "#/backend/entities/Expense"
          },
          "description": "Stores expense data for a specific user. Path-based ownership ensures only the user can access their expense data.",
          "params": [
            {
              "name": "userId",
              "description": "The ID of the user who owns the expense data."
            },
            {
              "name": "expenseId",
              "description": "The ID of the expense entry."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/appointments/{appointmentId}",
        "definition": {
          "entityName": "Appointment",
          "schema": {
            "$ref": "#/backend/entities/Appointment"
          },
          "description": "Stores appointment data for a specific user. Path-based ownership ensures only the user can access their appointment data.",
          "params": [
            {
              "name": "userId",
              "description": "The ID of the user who owns the appointment data."
            },
            {
              "name": "appointmentId",
              "description": "The ID of the appointment entry."
            }
          ]
        }
      }
    ],
    "reasoning": "The Firestore structure is designed to provide a secure and scalable foundation for the BizBoard application, focusing on clear ownership and authorization. Each user's data (revenues, expenses, and appointments) is stored under their respective user ID, ensuring data isolation and simplified security rules. This design avoids complex queries and `get()` calls in security rules, which aligns with the principles of Authorization Independence and facilitates easier debugging. The use of path-based ownership `/users/{userId}/revenues/{revenueId}` makes it straightforward to implement security rules that grant access only to the owner of the data.\n\n*   **Authorization Independence:** Achieved by structuring data under user-specific paths, eliminating the need for `get()` calls to parent documents for authorization. All data needed for authorization is implicitly available in the path.\n*   **QAPs:** Secure list operations are supported by the path-based ownership model. Listing revenues, expenses, or appointments is always scoped to a specific user, preventing unauthorized access to other users' data.\n\nBy adhering to these principles, the data structure promotes a maintainable and secure application."
  }
}
