
{
  "entities": {
    "AppSettings": {
        "title": "Application Settings",
        "type": "object",
        "description": "Stores global application settings like version number.",
        "properties": {
            "version": {
                "type": "string",
                "description": "The application version string."
            }
        }
    },
    "Sensor": {
      "title": "Sensor",
      "type": "object",
      "description": "Represents an IoT sensor device.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["TOF200C", "Temperatuur", "Luchtkwaliteit", "GPS Tracker", "Waterpeil"] },
        "status": { "type": "string", "enum": ["Online", "Offline", "Batterij laag", "Onderhoud"] },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "batteryLevel": { "type": "number" },
        "vulgraad": { "type": "number", "description": "Percentage gevuld (0-100)" },
        "currentDistanceCm": { "type": "number", "description": "Laatst gemeten afstand in cm" },
        "binDepthCm": { "type": "number", "description": "Totale diepte van de bak in cm voor kalibratie" },
        "measurementFrequency": { "type": "number", "description": "Aantal metingen per 24 uur" }
      },
      "required": ["id", "name", "type", "status"]
    },
    "Folder": {
        "title": "Folder",
        "type": "object",
        "description": "Represents a folder to organize files.",
        "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "createdAt": { "type": "string", "format": "date-time" },
            "folderId": {
                "type": ["string", "null"],
                "description": "The ID of the parent folder. Null if in root."
            }
        },
        "required": ["name", "createdAt"]
    },
    "Besteksmelding": {
      "title": "Besteksmelding",
      "type": "object",
      "description": "Represents a report related to a specific work item in the project specifications (bestek).",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "werksoort": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "omschrijving": { "type": "string" },
        "fotos": { "type": "array", "items": { "type": "string" } },
        "datum": { "type": "string", "format": "date" },
        "status": {
          "type": "string",
          "enum": ["Nieuw", "In behandeling", "Afgerond"]
        }
      },
      "required": ["projectId", "werksoort", "latitude", "longitude", "datum", "status"]
    },
    "Route": {
      "title": "Route",
      "type": "object",
      "description": "Represents a user-driven route history.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "projectId": { "type": "string" },
        "originalRouteId": { "type": "string" },
        "routeName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "allObjectIds": { "type": "array", "items": { "type": "string" } },
        "completedObjects": { "type": "array", "items": { "type": "string" } },
        "skippedObjects": { "type": "array", "items": { "type": "string" } },
        "totalObjects": { "type": "number" }
      },
      "required": ["userId", "projectId", "originalRouteId", "routeName", "date", "startTime"]
    },
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "type": "object",
      "description": "Represents a project.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the project."
        },
        "projectnummer": {
          "type": "string"
        },
        "projectnaam": {
          "type": "string"
        },
        "locatie": {
          "type": "string"
        },
        "opdrachtgever": {
          "type": "string"
        },
        "startdatum": {
          "type": "string",
          "format": "date"
        },
        "einddatum": {
          "type": "string",
          "format": "date"
        },
        "bestek": {
          "type": "string"
        },
        "besteknummer": {
          "type": "string"
        },
        "versie": {
          "type": "string"
        },
        "datum": {
          "type": "string",
          "format": "date"
        },
        "omschrijving": {
          "type": "string"
        },
        "werksoorten": {
          "type": "array",
          "items": {
            "$ref": "#/backend/entities/Werksoort"
          }
        },
        "wijken": {
          "type": "array",
          "items": {
            "$ref": "#/backend/entities/Wijk"
          }
        },
        "veegroutes": {
          "type": "array",
          "items": {
            "$ref": "#/backend/entities/Veegroute"
          }
        },
        "prullenbakkenroutes": {
            "type": "array",
            "items": {
                "$ref": "#/backend/entities/Prullenbakkenroute"
            }
        },
        "vehicleAvailability": {
          "type": "object",
          "description": "Stores vehicle availability per day for this project.",
          "properties": {
            "unavailable": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "available": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "required": [
        "projectnummer",
        "projectnaam"
      ]
    },
    "Werksoort": {
      "title": "Werksoort",
      "type": "object",
      "description": "Represents a work type within a project specification.",
      "properties": {
        "id": { "type": "string" },
        "postnummer": { "type": "string" },
        "werksoort": { "type": "string" },
        "eenheid": { "type": "string" },
        "fictieveH": { "type": "string" },
        "uurprijs": { "type": "string" }
      },
      "required": ["id", "werksoort"]
    },
    "Wijk": {
        "title": "Wijk",
        "type": "object",
        "description": "Represents a district within a project.",
        "properties": {
            "id": { "type": "string" },
            "naam": { "type": "string" },
            "locatie": { "type": "string" },
            "subGebieden": { "type": "string" },
            "roadTypes": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["naam"]
    },
    "Veegroute": {
        "title": "Veegroute",
        "type": "object",
        "description": "Represents a sweeping route within a project.",
        "properties": {
            "id": { "type": "string" },
            "naam": { "type": "string" },
            "locatie": { "type": "string" },
            "subGebieden": { "type": "string" },
            "roadTypes": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["naam"]
    },
    "Prullenbakkenroute": {
        "title": "Prullenbakkenroute",
        "type": "object",
        "description": "Represents a trash can route within a project.",
        "properties": {
            "id": { "type": "string" },
            "naam": { "type": "string" },
            "locatie": { "type": "string" },
            "subGebieden": { "type": "string" },
            "roadTypes": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["naam"]
    },
    "Boekingregel": {
        "title": "Boekingregel",
        "type": "object",
        "description": "Represents an internal booking rule for work planning.",
        "properties": {
            "id": { "type": "string" },
            "naam": { "type": "string" }
        },
        "required": ["naam"]
    },
     "Object": {
      "title": "Object",
      "type": "object",
      "description": "Represents a physical object in the world.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the object." },
        "latitude": { "type": "number", "description": "The latitude coordinate of the object." },
        "longitude": { "type": "number", "description": "The longitude coordinate of the object." },
        "locatieType": { "type": "string" },
        "locatieSubType": { "type": "string" },
        "kwaliteit": { "type": "string" },
        "isActief": { "type": "boolean" },
        "straatnaam": { "type": "string" },
        "huisnummer": { "type": "string" },
        "waarschuwing": { "type": "string" },
        "vulgraad": { "type": "number" },
        "locatieWerkgebieden": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "latitude", "longitude"]
    },
    "Bestand": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Bestand",
      "type": "object",
      "description": "Represents a file with its metadata.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "size": {
          "type": "number"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "uploadedAt": {
          "type": "string",
          "format": "date-time"
        },
        "storagePath": {
          "type": "string"
        },
        "folderId": {
          "type": ["string", "null"],
          "description": "The ID of the folder this file belongs to. Null if in root."
        }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile and display preferences.",
      "properties": {
        "id": {
          "type": "string",
          "description": "The user's unique ID, same as their auth UID."
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "displayName": {
          "type": "string"
        },
        "firstName": {
          "type": "string",
          "description": "The user's first name."
        },
        "lastName": {
          "type": "string",
          "description": "The user's last name."
        },
        "sidebarCollapsed": {
          "boolean": "description",
          "description": "User's preference for the sidebar state."
        },
        "role": {
          "type": "string",
          "description": "User role for display purposes."
        },
        "permissions": {
          "type": "object",
          "description": "Granular permissions for the user, structured by module.",
          "additionalProperties": {
            "type": "object",
            "description": "Action-based permissions for a module.",
            "additionalProperties": {
              "type": "boolean"
            }
          }
        },
        "wijk": {
            "type": "string",
            "description": "The district/area the user is associated with."
        },
        "veegroute": {
            "type": "string",
            "description": "The sweeping route the user is associated with."
        },
        "prullenbakkenroute": {
            "type": "string",
            "description": "The trash can route the user is associated with."
        },
        "schouwenGemeente": {
          "type": "string",
          "description": "The municipality the user is associated with for inspections (schouwen)."
        },
        "schouwenMapStyle": {
            "type": "string",
            "description": "The user's preferred map style for the inspection map."
        },
        "lastSelectedProjectId": {
            "type": ["string", "null"],
            "description": "The ID of the last project the user selected."
        },
        "nfcTagId": {
          "type": "string",
          "description": "Unique identifier of the user's NFC tag for login."
        }
      },
      "required": [
        "id"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/sensors/{sensorId}",
        "definition": {
          "entityName": "Sensor",
          "schema": { "$ref": "#/backend/entities/Sensor" },
          "description": "Stores IoT sensor data.",
          "params": [
            { "name": "sensorId", "description": "The unique ID of the sensor." }
          ]
        }
      },
      {
        "path": "/settings/{docId}",
        "definition": {
          "entityName": "AppSettings",
          "schema": {
            "$ref": "#/backend/entities/AppSettings"
          },
          "description": "Stores global application settings. Use a specific document ID like 'main' for specific settings.",
          "params": [
            {
              "name": "docId",
              "description": "The ID of the setting document (e.g., 'main')."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores user-specific profile data and preferences.",
          "params": [
            {
              "name": "userId",
              "description": "The ID of the user."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/routes/{routeId}",
        "definition": {
            "entityName": "Route",
            "schema": { "$ref": "#/backend/entities/Route" },
            "description": "Stores user-specific route history.",
            "params": [
                { "name": "userId", "description": "The ID of the user." },
                { "name": "routeId", "description": "The ID of the route history entry." }
            ]
        }
      },
      {
        "path": "/projects/{projectId}",
        "definition": {
          "entityName": "Project",
          "schema": {
            "$ref": "#/backend/entities/Project"
          },
          "description": "Stores all projects for the application.",
          "params": [
            {
              "name": "projectId",
              "description": "The ID of the project."
            }
          ]
        }
      },
      {
        "path": "/projects/{projectId}/besteksmeldingen/{besteksmeldingId}",
        "definition": {
          "entityName": "Besteksmelding",
          "schema": {
            "$ref": "#/backend/entities/Besteksmelding"
          },
          "description": "Stores specification reports for a specific project.",
          "params": [
            {
              "name": "projectId",
              "description": "The ID of the project."
            },
            {
              "name": "besteksmeldingId",
              "description": "The ID of the specification report."
            }
          ]
        }
      },
      {
        "path": "/projects/{projectId}/bestanden/{bestandId}",
        "definition": {
          "entityName": "Bestand",
          "schema": {
            "$ref": "#/backend/entities/Bestand"
          },
          "description": "Stores files for a specific project.",
          "params": [
            {
              "name": "projectId",
              "description": "The ID of the project."
            },
            {
              "name": "bestandId",
              "description": "The ID of the file."
            }
          ]
        }
      },
      {
        "path": "/projects/{projectId}/folders/{folderId}",
        "definition": {
          "entityName": "Folder",
          "schema": {
            "$ref": "#/backend/entities/Folder"
          },
          "description": "Stores folders for a specific project.",
          "params": [
            {
              "name": "projectId",
              "description": "The ID of the project."
            },
            {
              "name": "folderId",
              "description": "The ID of the folder."
            }
          ]
        }
      },
      {
        "path": "/medewerkers/{medewerkerId}",
        "definition": {
            "entityName": "Medewerker",
            "schema": { "$ref": "#/backend/entities/Medewerker" },
            "description": "Stores all employees for the application.",
            "params": [
                { "name": "medewerkerId", "description": "The ID of the employee." }
            ]
        }
      },
      {
        "path": "/objects/{objectId}",
        "definition": {
          "entityName": "Object",
          "schema": { "$ref": "#/backend/entities/Object" },
          "description": "Stores all physical objects for the application.",
          "params": [
            { "name": "objectId", "description": "The ID of the object." }
          ]
        }
      },
      {
        "path": "/meldingen/{meldingId}",
        "definition": {
          "entityName": "Melding",
          "schema": { "$ref": "#/backend/entities/Melding" },
          "description": "Stores all issues/reports for the application.",
          "params": [
            { "name": "meldingId", "description": "The ID of the issue." }
          ]
        }
      }
    ]
  }
}
